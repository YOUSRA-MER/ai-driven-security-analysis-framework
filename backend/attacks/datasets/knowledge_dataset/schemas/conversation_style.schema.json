{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "conversation_style.schema.json",
  "title": "Knowledge Conversation Style",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "description", "version", "status", "turn_pattern", "turn_limits", "stop_conditions", "created_at", "updated_at"],
  "properties": {
    "id": {"type": "string", "pattern": "^style-[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "name": {"type": "string", "minLength": 3, "maxLength": 120},
    "description": {"type": "string", "minLength": 20, "maxLength": 1000},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "status": {"type": "string", "enum": ["draft", "active", "deprecated"]},
    "tags": {"type": "array", "items": {"type": "string", "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"}, "uniqueItems": true},
    "turn_pattern": {"type": "string", "enum": ["single_turn", "bounded_multi_turn", "retrieval_augmented", "tool_mediated", "mixed"]},
    "state_requirements": {"type": "array", "items": {"type": "string", "minLength": 5}},
    "turn_limits": {"type": "object", "additionalProperties": false, "required": ["min", "max", "preferred"], "properties": {"min": {"type": "integer", "minimum": 1}, "max": {"type": "integer", "minimum": 1}, "preferred": {"type": "integer", "minimum": 1}}},
    "recommended_for": {"type": "array", "items": {"type": "string", "pattern": "^(af|strat)-[a-z0-9]+(?:-[a-z0-9]+)*$"}, "uniqueItems": true},
    "stop_conditions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5}},
    "references": {"type": "array", "items": {"type": "string", "pattern": "^ref-[a-z0-9]+(?:-[a-z0-9]+)*$"}, "uniqueItems": true},
    "created_at": {"type": "string", "format": "date"},
    "updated_at": {"type": "string", "format": "date"}
  }
}
