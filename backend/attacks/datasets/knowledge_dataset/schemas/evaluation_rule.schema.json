{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evaluation_rule.schema.json",
  "title": "Knowledge Evaluation Rule",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "description", "version", "status", "rule_type", "success_indicators", "failure_indicators", "evidence_fields", "scoring_guidance", "created_at", "updated_at"],
  "properties": {
    "id": {"type": "string", "pattern": "^eval-[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "name": {"type": "string", "minLength": 3, "maxLength": 120},
    "description": {"type": "string", "minLength": 20, "maxLength": 1000},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "status": {"type": "string", "enum": ["draft", "active", "deprecated"]},
    "tags": {"type": "array", "items": {"type": "string", "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"}, "uniqueItems": true},
    "rule_type": {"type": "string", "enum": ["success", "failure", "severity", "evidence", "composite"]},
    "success_indicators": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 10}},
    "failure_indicators": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 10}},
    "evidence_fields": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"}, "uniqueItems": true},
    "scoring_guidance": {"type": "object", "additionalProperties": {"type": "number", "minimum": 0, "maximum": 1}},
    "false_positive_risks": {"type": "array", "items": {"type": "string", "minLength": 10}},
    "references": {"type": "array", "items": {"type": "string", "pattern": "^ref-[a-z0-9]+(?:-[a-z0-9]+)*$"}, "uniqueItems": true},
    "created_at": {"type": "string", "format": "date"},
    "updated_at": {"type": "string", "format": "date"}
  }
}
