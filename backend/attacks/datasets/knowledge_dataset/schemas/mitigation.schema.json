{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mitigation.schema.json",
  "title": "Knowledge Mitigation",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "description", "version", "status", "control_category", "mitigates", "implementation_guidance", "verification_methods", "created_at", "updated_at"],
  "properties": {
    "id": {"type": "string", "pattern": "^mit-[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "name": {"type": "string", "minLength": 3, "maxLength": 120},
    "description": {"type": "string", "minLength": 20, "maxLength": 1000},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "status": {"type": "string", "enum": ["draft", "active", "deprecated"]},
    "tags": {"type": "array", "items": {"type": "string", "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"}, "uniqueItems": true},
    "control_category": {"type": "string", "enum": ["policy", "architecture", "detection", "training", "evaluation", "operations"]},
    "mitigates": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^(obj|af)-[a-z0-9]+(?:-[a-z0-9]+)*$"}, "uniqueItems": true},
    "implementation_guidance": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 10}},
    "verification_methods": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 10}},
    "owasp_mappings": {"type": "array", "items": {"type": "string", "pattern": "^owasp-[a-z0-9]+(?:-[a-z0-9]+)*$"}, "uniqueItems": true},
    "mitre_mappings": {"type": "array", "items": {"type": "string", "pattern": "^atlas-[a-z0-9]+(?:-[a-z0-9]+)*$"}, "uniqueItems": true},
    "references": {"type": "array", "items": {"type": "string", "pattern": "^ref-[a-z0-9]+(?:-[a-z0-9]+)*$"}, "uniqueItems": true},
    "created_at": {"type": "string", "format": "date"},
    "updated_at": {"type": "string", "format": "date"}
  }
}
