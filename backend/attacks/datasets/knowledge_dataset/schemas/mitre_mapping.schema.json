{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mitre_mapping.schema.json",
  "title": "Knowledge MITRE ATLAS Mapping",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "description", "version", "status", "atlas_id", "atlas_name", "mapping_type", "planning_relevance", "created_at", "updated_at"],
  "properties": {
    "id": {"type": "string", "pattern": "^atlas-[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "name": {"type": "string", "minLength": 3, "maxLength": 120},
    "description": {"type": "string", "minLength": 20, "maxLength": 1000},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "status": {"type": "string", "enum": ["draft", "active", "deprecated"]},
    "tags": {"type": "array", "items": {"type": "string", "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"}, "uniqueItems": true},
    "atlas_id": {"type": "string", "pattern": "^AML\\.[A-Z0-9]+(?:\\.[A-Z0-9]+)?$"},
    "atlas_name": {"type": "string", "minLength": 3, "maxLength": 120},
    "mapping_type": {"type": "string", "enum": ["tactic", "technique", "subtechnique"]},
    "planning_relevance": {"type": "string", "minLength": 20, "maxLength": 500},
    "related_entities": {"type": "array", "items": {"type": "string", "pattern": "^(obj|af|strat|mut|style|model|eval|mit)-[a-z0-9]+(?:-[a-z0-9]+)*$"}, "uniqueItems": true},
    "references": {"type": "array", "items": {"type": "string", "pattern": "^ref-[a-z0-9]+(?:-[a-z0-9]+)*$"}, "uniqueItems": true},
    "created_at": {"type": "string", "format": "date"},
    "updated_at": {"type": "string", "format": "date"}
  }
}
