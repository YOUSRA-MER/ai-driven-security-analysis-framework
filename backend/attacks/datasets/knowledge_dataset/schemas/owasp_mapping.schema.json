{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "owasp_mapping.schema.json",
  "title": "Knowledge OWASP Mapping",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "description", "version", "status", "owasp_version", "category_id", "category_name", "planning_relevance", "created_at", "updated_at"],
  "properties": {
    "id": {"type": "string", "pattern": "^owasp-[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "name": {"type": "string", "minLength": 3, "maxLength": 120},
    "description": {"type": "string", "minLength": 20, "maxLength": 1000},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "status": {"type": "string", "enum": ["draft", "active", "deprecated"]},
    "tags": {"type": "array", "items": {"type": "string", "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"}, "uniqueItems": true},
    "owasp_version": {"type": "string", "pattern": "^[0-9]{4}(?:\\.[0-9]+)?$"},
    "category_id": {"type": "string", "pattern": "^LLM[0-9]{2}$"},
    "category_name": {"type": "string", "minLength": 3, "maxLength": 120},
    "planning_relevance": {"type": "string", "minLength": 20, "maxLength": 500},
    "related_entities": {"type": "array", "items": {"type": "string", "pattern": "^(obj|af|strat|mut|style|model|eval|mit)-[a-z0-9]+(?:-[a-z0-9]+)*$"}, "uniqueItems": true},
    "references": {"type": "array", "items": {"type": "string", "pattern": "^ref-[a-z0-9]+(?:-[a-z0-9]+)*$"}, "uniqueItems": true},
    "created_at": {"type": "string", "format": "date"},
    "updated_at": {"type": "string", "format": "date"}
  }
}
