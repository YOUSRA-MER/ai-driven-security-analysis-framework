{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "reference.schema.json",
  "title": "Knowledge Reference",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "description", "version", "status", "source_type", "citation", "relevance", "created_at", "updated_at"],
  "properties": {
    "id": {"type": "string", "pattern": "^ref-[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "name": {"type": "string", "minLength": 3, "maxLength": 160},
    "description": {"type": "string", "minLength": 20, "maxLength": 1000},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "status": {"type": "string", "enum": ["draft", "active", "deprecated"]},
    "tags": {"type": "array", "items": {"type": "string", "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"}, "uniqueItems": true},
    "source_type": {"type": "string", "enum": ["paper", "standard", "repository", "documentation", "blog", "internal_note"]},
    "authors": {"type": "array", "items": {"type": "string", "minLength": 2}},
    "published_at": {"type": "string", "pattern": "^[0-9]{4}(?:-[0-9]{2}-[0-9]{2})?$"},
    "url": {"type": "string", "format": "uri"},
    "citation": {"type": "string", "minLength": 5, "maxLength": 500},
    "relevance": {"type": "string", "minLength": 20, "maxLength": 500},
    "references": {"type": "array", "items": {"type": "string", "pattern": "^ref-[a-z0-9]+(?:-[a-z0-9]+)*$"}, "uniqueItems": true},
    "created_at": {"type": "string", "format": "date"},
    "updated_at": {"type": "string", "format": "date"}
  }
}
